# ============================================================
# AI-Solutions — Apache .htaccess
# ============================================================

# Custom error pages
ErrorDocument 404 /ai_solutions/404.php

# Disable directory listing (security)
Options -Indexes

# Prevent access to sensitive files
<FilesMatch "\.(sql|log|sh|env|md|gitignore)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Block access to includes directory directly
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^includes/ - [F,L]
    RewriteRule ^uploads/.*\.php$ - [F,L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# PHP file upload and execution limits (adjust if needed)
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 12M
    php_value max_execution_time 60
    php_value memory_limit 128M
</IfModule>

# Enable GZIP compression for better performance
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript
</IfModule>

# Browser caching for static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css         "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/jpeg       "access plus 1 month"
    ExpiresByType image/png        "access plus 1 month"
    ExpiresByType image/webp       "access plus 1 month"
    ExpiresByType image/gif        "access plus 1 month"
</IfModule>
